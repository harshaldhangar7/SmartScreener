# Database configuration
DATABASE_URL=mysql://root:harshal@localhost/smartscreener

# Session secret key for Flask session management
#
# SECURITY NOTE: This should be a long, random string (at least 32 characters)
# Generate a secure secret using:
#   Python: secrets.token_urlsafe(32)
#   CLI: openssl rand -base64 32
#
# DO NOT use the default value in production environments
SESSION_SECRET=your-secret-key-here

# Embedding model (optional, defaults to all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2